MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/trampei
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=development

# URL do frontend (CORS). Na Vercel use a URL de produção (ex.: https://trampei.vercel.app)
# Vários valores: CLIENT_URLS_EXTRA=https://preview-1.vercel.app,https://preview-2.vercel.app
CLIENT_URL=http://localhost:3000
CLIENT_URLS_EXTRA=

# Cloudinary (upload de imagens — opcional em dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP opcional para recuperação de senha
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Trampei <no-reply@seudominio.com>

# Anti-spam: intervalo mínimo entre posts de serviço (ms)
MIN_MS_BETWEEN_SERVICE_POSTS=120000
